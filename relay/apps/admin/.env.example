# Admin UI configuration. Copy to `.env` for local dev.

# Postgres the relay reads its `write_allowlist` table from (same DB as the relay).
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# Seeds the `admins` table on first boot when it's empty (comma/space-separated,
# hex or npub). Admins are managed in the UI thereafter; this is just bootstrap/
# recovery. Empty env + empty table = nobody can sign in (fails closed).
ADMIN_PUBKEYS=

# Secret used to seal the admin session cookie (>= 32 chars). REQUIRED in production.
ADMIN_SESSION_SECRET=
