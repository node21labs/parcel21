# Local development — matches docker-compose.yml
DATABASE_URL=postgres://relay:relay@localhost:5432/relay

# Production (Neon, pooled) — set in your deployment environment, not in .env
# Use the "pooled" connection string from the Neon dashboard; it ends in "-pooler".
# DATABASE_URL=postgres://<user>:<password>@ep-<name>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
