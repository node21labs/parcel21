{
  "name": "@relay/db",
  "version": "0.0.0",
  "description": "Postgres schema and Drizzle client for the relay.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
