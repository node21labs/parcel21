    "db:migrate": "vp exec drizzle-kit migrate",
    "db:push": "vp exec drizzle-kit push",
    "db:studio": "vp exec drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  }
}
