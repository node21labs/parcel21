{
  "name": "parcel21-demo-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hosted one-click demo: a real RGB asset transfer over the Parcel21 relay on public Mutinynet, returning verifiable links.",
  "scripts": {
    "vendor": "mkdir -p src/_vendor && cp ../client/src/lib/parcel21.ts src/_vendor/parcel21.ts",
    "dev": "npm run vendor && tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "npm run vendor && tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.2",
    "bitcoinjs-lib": "^6.1.7",
    "fastify": "^5.2.1",
    "nostr-tools": "2.23.5",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3"
  }
}
